# Docker Registry Configuration
DOCKER_REGISTRY=iamrahulgupta
DOCKER_IMAGE_NAME=github-project-streamforge

# Broker Configuration - Common Settings
BROKER_LISTEN_ADDR=0.0.0.0
BROKER_DATA_DIR=/data/streamforge
BROKER_LOG_LEVEL=info

# Broker 1 Configuration
BROKER_1_ID=1
BROKER_1_PORT=9092
BROKER_1_METRICS_PORT=9101

# Broker 2 Configuration
BROKER_2_ID=2
BROKER_2_PORT=9093
BROKER_2_METRICS_PORT=9102

# Broker 3 Configuration
BROKER_3_ID=3
BROKER_3_PORT=9094
BROKER_3_METRICS_PORT=9103

# Admin Configuration
ADMIN_PORT=8080
ADMIN_LOG_LEVEL=info

# Prometheus Configuration
PROMETHEUS_PORT=9090

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
GRAFANA_PORT=3000

# Network Configuration
NETWORK_DRIVER=bridge
